# ── Cloudflare Workers secret configuration ──────────────────────────────────
#
# This project runs on Cloudflare Workers, which does NOT use .env files.
# Secrets are provided differently depending on environment:
#
# LOCAL DEV (wrangler dev):
#   Copy this file to .dev.vars and fill in real values.
#   .dev.vars is gitignored and must never be committed.
#
#     cp .env.example .dev.vars
#     # then edit .dev.vars with your real credentials
#
# PRODUCTION (deployed Worker):
#   Set secrets via Wrangler CLI (run once per secret):
#
#     npx wrangler secret put WALMART_CLIENT_ID
#     npx wrangler secret put WALMART_CLIENT_SECRET
#
#   Or set them in the Cloudflare dashboard:
#   Workers → your-worker → Settings → Variables & Secrets
#
# ─────────────────────────────────────────────────────────────────────────────

# Walmart Marketplace API credentials
# Obtain all values from: Seller Center → Settings → Developer Settings → API Keys

# Your Client ID (also called Consumer ID)
WALMART_CLIENT_ID=your_client_id_here

# Your Client Secret
WALMART_CLIENT_SECRET=your_client_secret_here

# Optional: Channel Type ID (UUID — separate from Client ID, used for request tracking)
# If omitted, the header is skipped and the API functions normally.
# WALMART_CHANNEL_TYPE=your_channel_type_uuid_here
