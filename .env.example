# Walmart Marketplace API credentials
# All three values are required — obtain them from:
# Seller Center → Settings → Developer Settings → API Keys

# Your Client ID (also called Consumer ID)
WALMART_CLIENT_ID=your_client_id_here

# Your Client Secret
WALMART_CLIENT_SECRET=your_client_secret_here

# Your Channel Type ID (UUID — distinct from Client ID)
# Found on the API Keys page, labeled "Channel Type"
WALMART_CHANNEL_TYPE=your_channel_type_uuid_here

# Optional: override the API base URL (defaults to https://marketplace.walmartapis.com)
# WALMART_API_BASE_URL=https://marketplace.walmartapis.com
